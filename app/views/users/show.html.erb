<h1><%= profile_title %> Page</h1>

<% if @user.bio.present? %>
  <p><%= @user.bio %></p>
<% end %>

<% if @user.avatar_url.present? %>
  <img
    src="<%= @user.avatar_url %>"
    alt="<%= @user.username %>"
  />
<% end %>

<% if flash[:success] %>
  <p class="flash-success"><%= flash[:success] %></p>
<% elsif flash[:failure] %>
  <p class="flash-failure">Error: <%= flash[:failure] %></p>
<% end %>

<%= render "follows" %>

<% if @user_posts.any? %>
  <h2>Posts</h2>

  <ul>
    <% @user_posts.each do |post| %>
      <li>
        <h3><%= link_to post.title, post %></h3>
        <p><%= truncate(post.text, length: 100) %></p>
      </li>
    <% end %>
  </ul>
<% end %>