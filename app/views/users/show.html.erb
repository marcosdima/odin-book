<div class="user-container">
  <div class="user-header">
    <% if @user.avatar_url.present? %>
      <img
        class="user-avatar"
        src="<%= @user.avatar_url %>"
        alt="<%= @user.username %>"
      />
    <% end %>

    <div class="user-info">
      <h1 class="user-title"><%= profile_title %> Page</h1>

      <% if @user.bio.present? %>
        <p class="user-bio"><%= @user.bio %></p>
      <% end %>
    </div>
  </div>
  
  <%= render "follows" %>

  <% if @user_posts.any? %>
    <section class="user-posts">
      <h2>Posts</h2>

      <ul class="user-post-list">
        <% @user_posts.each do |post| %>
          <li class="user-post">
            <h3 class="user-post-title">
              <%= link_to post.title, post, class: "user-post-link" %>
            </h3>

            <p class="user-post-text">
              <%= truncate(post.text, length: 100) %>
            </p>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</div>