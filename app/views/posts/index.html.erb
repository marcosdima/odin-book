<h1>Posts</h1>

<% if user_signed_in? %>
  <%= link_to 'New Post', new_post_path %>
<% end %>

<% if @posts.any? %>
  <ul>
    <% @posts.each do |post| %>
      <li>
        <h3><%= link_to post.title, post %></h3>
        <p><%= truncate(post.text, length: 100) %></p>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No posts yet.</p>
<% end %>