<% if likeable && !already_liked?(likeable) %>
  <%= button_to unlike_likes_path,
    method: :delete,
    params: like_params_for(likeable),
    class: "btn" do %>
    ♥ <span><%= likeable.likes.count %></span>
  <% end %>
  <% else %>
    <%= button_to likes_path,
      method: :post,
      params: like_params_for(likeable),
      class: "btn" do %>
      ♡ <span><%= likeable.likes.count %></span>
  <% end %>
<% else %>
  <div class="btn">
    ♥ <span><%= likeable.likes.count %></span>
  </div>
<% end %>