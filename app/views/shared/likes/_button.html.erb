<% if user_signed_in? %>
  <% if already_liked?(likeable) %>
    <%= button_to "Unlike",
        unlike_likes_path,
        method: :delete,
        params: like_params_for(likeable) %>
  <% else %>
    <%= button_to "Like",
        likes_path,
        method: :post,
        params: like_params_for(likeable) %>
  <% end %>
<% end %>