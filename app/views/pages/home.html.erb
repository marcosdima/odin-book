<div class="home">
  <section class="hero">
    <h1>Welcome to OdinBook</h1>
    <p>Connect with friends and the world around you on OdinBook.</p>
  </section>

  <section class="post-section">
    <h2>Recent <%= link_to "Posts", posts_path %></h2>

    <div class="post-grid">
      <% @recent_posts.each do |post| %>
        <article class="post-card">
          <div class="post-content">
            <h3><%= link_to post.title, post_path(post) %></h3>
            <p><%= truncate(post.text, length: 100) %></p>
          </div>
          <div class="post-stats">
            <%= render "shared/like_button", likeable: post %>
            <%= render "shared/comments/count", commentable: post %>
          </div>
        </article>
      <% end %>
    </div>
  </section>
</div>