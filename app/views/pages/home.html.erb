<div class="home">
  <section class="hero">
    <h1>Welcome to OdinBook</h1>
    <p>Connect with friends and the world around you on OdinBook.</p>
  </section>

  <section class="post-section">
    <h2 class="post-section-title">
      Recent
      <%= button_to "Posts", posts_path, method: :get, class: "btn" %>
    </h2>

    <div class="post-grid">
      <%= render "shared/posts_display", posts: @recent_posts %>
    </div>
  </section>
</div>